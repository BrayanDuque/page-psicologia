# Configuración del servidor
PORT=3000
NODE_ENV=development

# URL del frontend (cambiar en producción)
FRONTEND_URL=http://localhost:5173

# Base de datos
DATABASE_URL=./database/psicologia.db

# Configuración de email (Gmail recomendado para desarrollo)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu-email@gmail.com
EMAIL_PASS=tu-contraseña-app-gmail
EMAIL_FROM=tu-email@gmail.com

# JWT Secret (para futuras funcionalidades de autenticación)
JWT_SECRET=tu-secreto-jwt-muy-seguro-aqui-cambiar-en-produccion

# Configuración de uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Configuración adicional
LOG_LEVEL=combined
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100